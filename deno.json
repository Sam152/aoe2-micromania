{
  "nodeModulesDir": "auto",
  "vendor": true,
  "tasks": {
    "start": "deno run --check -A src/start.ts",
    "start:debug": "deno run --inspect --check -A src/start.ts",
    "start:watch": "deno run --allow-run=deno .hooks/watch-forever.ts",
    "hooks:init": "git config core.hooksPath .hooks",
    "on-save": "deno --allow-run .hooks/on-save.ts",
    "training:docker-start": "docker compose -f src/common/ai/training/infra/docker-compose.yml up -d",
    "training:dump": "PGPASSWORD=postgres pg_dump -h localhost -p 8345 -U postgres postgres > src/common/ai/training/infra/data/dump.sql && PGPASSWORD=postgres pg_dump --schema-only -h localhost -p 8345 -U postgres postgres > src/common/ai/training/infra/data/schema.sql"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "npm:react@18",
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"],
    "noImplicitAny": true
  },
  "fmt": {
    "lineWidth": 120,
    "useBraces": "always"
  },
  "lint": {
    "plugins": [
      "jsr:@hirochachacha/deno-lint-plugin-unused-fixer"
    ],
    "rules": {
      "include": [
        "no-default-export"
      ],
      "exclude": [
        "unused-fixer/no-unused-vars",
        "require-await",
        "no-explicit-any"
      ]
    }
  },
  "test": {
    "permissions": {
      "read": true,
      "write": true
    }
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.29",
    "@std/testing": "jsr:@std/testing@^1.0.19",
    "@std/testing/bdd": "jsr:@std/testing/bdd",
    "@types/d3-quadtree": "npm:@types/d3-quadtree@^3.0.6",
    "@types/react": "npm:@types/react@^18",
    "@types/react-dom": "npm:@types/react-dom@^18",
    "@luca/esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@^0.11.1",
    "@std/crypto": "jsr:@std/crypto@^1.1.0",
    "esbuild": "npm:esbuild@0.28.0",
    "@types/three": "npm:@types/three@^0.184.1",
    "pino": "npm:pino@^10.3.1",
    "react": "npm:react@18",
    "react/jsx-runtime": "npm:react@18/jsx-runtime",
    "react-dom": "npm:react-dom@18",
    "react-dom/client": "npm:react-dom@18/client",
    "react-router-dom": "npm:react-router-dom@^6.3.0",
    "socket.io": "npm:socket.io@^4.4.1",
    "socket.io-client": "npm:socket.io-client@^4.4.1",
    "three": "npm:three@~0.139.2",
    "howler": "npm:howler@^2.2.3",
    "d3-quadtree": "npm:d3-quadtree@^3.0.1",
    "humanize-duration": "npm:humanize-duration@^3.27.1",
    "jascpal": "npm:jascpal@~0.1.4",
    "just-standard-deviation": "npm:just-standard-deviation@^2.0.2"
  }
}
